# Docker reads the .dockerignore from the *build context root*. We build the
# image with the repo root as context (`docker build -f infra/Dockerfile .`,
# `gcloud run deploy --source .`, and infra/docker-compose.yml all use the repo
# root), so this is the file that actually shrinks the context. The serving
# image only needs: pyproject.toml, README.md, src/, configs/, dashboard/.

# Version control / CI
.git
.git/**
.github
.gitignore

# Python caches / build artifacts
__pycache__/
**/__pycache__/
*.py[cod]
*.egg-info/
**/*.egg-info/
build/
dist/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Tests are not needed in the runtime image
tests/

# Notebooks + checkpoints
notebooks/
**/.ipynb_checkpoints/
*.ipynb

# Generated pipeline outputs and any local data
outputs/
data/

# Docs are served separately; not needed by the API container
docs/

# Local env / secrets — never bake these into an image
.env
.env.*
!.env.example
*.pem
*.key
service-account*.json
gee-credentials*.json
.earthengine/

# Node / dashboard build tooling (the dashboard is plain static files)
node_modules/
dashboard/node_modules/
dashboard/dist/
dashboard/.parcel-cache/

# Editor / OS cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~
