# =============================================================================
# AgriStress — example environment configuration.
# Copy to `.env` and fill in real values. `.env` is gitignored; never commit it.
# All settings are consumed by `agristress.config.settings.Settings`
# (pydantic-settings), prefixed with AGRISTRESS_ unless noted otherwise.
# =============================================================================

# -----------------------------------------------------------------------------
# Google Earth Engine
# -----------------------------------------------------------------------------
# Cloud project that EE bills/quota is attached to (ee.Initialize(project=...)).
EE_PROJECT=your-gcp-project-id
# Service-account email for headless / server-side auth (optional in dev).
GEE_SERVICE_ACCOUNT=ee-runner@your-gcp-project-id.iam.gserviceaccount.com
# Absolute path to the service-account JSON key (kept OUT of the repo).
GEE_SERVICE_ACCOUNT_KEY=/secrets/gee-service-account.json
# Earth Engine high-volume endpoint toggle (true for batch/tile workloads).
EE_HIGH_VOLUME=false

# -----------------------------------------------------------------------------
# NASA Earthdata (Landsat / MODIS / SMAP / GPM via DAACs)
# -----------------------------------------------------------------------------
EARTHDATA_USERNAME=your-earthdata-username
EARTHDATA_PASSWORD=your-earthdata-password
EARTHDATA_TOKEN=your-earthdata-bearer-token

# -----------------------------------------------------------------------------
# Copernicus Data Space Ecosystem (Sentinel-1 / Sentinel-2)
# -----------------------------------------------------------------------------
COPERNICUS_CLIENT_ID=your-cdse-client-id
COPERNICUS_CLIENT_SECRET=your-cdse-client-secret
COPERNICUS_S3_ACCESS_KEY=your-cdse-s3-access-key
COPERNICUS_S3_SECRET_KEY=your-cdse-s3-secret-key

# -----------------------------------------------------------------------------
# Sentinel Hub (optional commercial OGC/Process API)
# -----------------------------------------------------------------------------
SENTINELHUB_CLIENT_ID=your-sentinelhub-client-id
SENTINELHUB_CLIENT_SECRET=your-sentinelhub-client-secret
SENTINELHUB_INSTANCE_ID=your-sentinelhub-instance-id

# -----------------------------------------------------------------------------
# Planet (optional high-res tasking / PlanetScope)
# -----------------------------------------------------------------------------
PLANET_API_KEY=your-planet-api-key

# -----------------------------------------------------------------------------
# ISRO / NRSC portals (Bhuvan / Bhoonidhi) — for LISS-III, AWiFS, EOS-04
# -----------------------------------------------------------------------------
BHUVAN_API_TOKEN=your-bhuvan-token
BHOONIDHI_USERNAME=your-bhoonidhi-username
BHOONIDHI_PASSWORD=your-bhoonidhi-password

# -----------------------------------------------------------------------------
# Infrastructure: cache + tile server + object storage
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
TILE_SERVER_URL=http://localhost:8001
# S3 / GCS bucket holding COG/Zarr datacubes (s3:// or gs:// URI).
DATACUBE_BUCKET=s3://agristress-datacubes
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_DEFAULT_REGION=ap-south-1

# -----------------------------------------------------------------------------
# Application runtime
# -----------------------------------------------------------------------------
AGRISTRESS_ENV=development            # development | staging | production
AGRISTRESS_LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
AGRISTRESS_LOG_JSON=false             # true => structured JSON logs
AGRISTRESS_DATA_DIR=./data
AGRISTRESS_CONFIG=configs/default.yaml
AGRISTRESS_DEFAULT_AOI=mula_nira_command
AGRISTRESS_API_HOST=0.0.0.0
AGRISTRESS_API_PORT=8000
