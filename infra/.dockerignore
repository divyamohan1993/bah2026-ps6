# Keep the Docker build context small and reproducible. The build only needs
# pyproject.toml, README.md, src/, configs/ and dashboard/ (see infra/Dockerfile).
# NOTE: docker uses the .dockerignore at the *build context root*. Build from the
# repo root with `-f infra/Dockerfile`; a copy of this file is symlinked/kept at
# the repo root is NOT required because we pass the context explicitly, but this
# file documents and (when used as the context's ignore) enforces the excludes.

# Version control / CI
.git
.git/**
.github
.gitignore

# Python caches / build artifacts
__pycache__/
**/__pycache__/
*.py[cod]
*.egg-info/
**/*.egg-info/
build/
dist/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Tests are not needed in the runtime image
tests/

# Notebooks + checkpoints
notebooks/
**/.ipynb_checkpoints/
*.ipynb

# Generated pipeline outputs and any local data
outputs/
data/

# Docs (served separately; not needed by the API container)
docs/

# Local env / secrets — never bake these into an image
.env
.env.*
!.env.example
*.pem
*.key
service-account*.json
gee-credentials*.json
.earthengine/

# Node / dashboard build tooling (the dashboard is plain static files)
node_modules/
dashboard/node_modules/
dashboard/dist/
dashboard/.parcel-cache/

# Editor / OS cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# Infra meta (don't recurse infra into the image)
infra/docker-compose.yml
